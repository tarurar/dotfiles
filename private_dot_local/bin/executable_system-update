#!/bin/bash

set -euo pipefail

LOCK_FILES=(
    /var/lib/apt/lists/lock
    /var/lib/dpkg/lock-frontend
    /var/lib/dpkg/lock
    /var/cache/apt/archives/lock
)

section() {
    echo
    echo "==> $1"
}

run_if_available() {
    local command_name="$1"
    shift

    if ! command -v "$command_name" >/dev/null 2>&1; then
        echo "Skipping $command_name: command not found"
        return
    fi

    "$@"
}

run_fwupdmgr() {
    if ! command -v fwupdmgr >/dev/null 2>&1; then
        echo "Skipping fwupdmgr: command not found"
        return
    fi

    local status=0
    fwupdmgr "$@" || status=$?

    if [[ "$status" -eq 2 ]]; then
        return
    fi

    return "$status"
}

show_mouse_battery_level() {
    if ! command -v solaar >/dev/null 2>&1; then
        echo "Skipping mouse battery level: solaar not found"
        return
    fi

    local battery_level
    battery_level="$(
        solaar show 2>/dev/null |
            awk -F'Battery: ' '/Battery:/ { value = $2 } END { print value }'
    )"

    if [[ -z "$battery_level" ]]; then
        echo "Skipping mouse battery level: unavailable"
        return
    fi

    echo "Mouse battery level: $battery_level"
}

lock_holders() {
    local lock_file="$1"

    if [[ ! -e "$lock_file" ]]; then
        return
    fi

    sudo fuser "$lock_file" 2>/dev/null || true
}

describe_process() {
    local pid="$1"

    ps -p "$pid" -o pid=,user=,etimes=,comm=,args= 2>/dev/null || echo " $pid <unknown>"
}

check_package_manager_locks() {
    local found_lock=0

    for lock_file in "${LOCK_FILES[@]}"; do
        local pids
        pids="$(lock_holders "$lock_file")"

        if [[ -z "$pids" ]]; then
            continue
        fi

        found_lock=1
        echo "Package manager lock is currently held: $lock_file"

        for pid in $pids; do
            describe_process "$pid"
        done

        echo
    done

    if [[ "$found_lock" -eq 0 ]]; then
        return
    fi

    echo "No updates were started."
    echo "Wait for the process to finish, or inspect it before taking manual action."
    echo "Do not remove apt or dpkg lock files."
    exit 2
}

check_package_manager_locks

section "APT"
sudo apt update
sudo apt upgrade --yes
sudo apt autoremove --yes

section "Flatpak"
run_if_available flatpak flatpak update

section "Snap"
run_if_available snap sudo snap refresh

section "Mise"
run_if_available mise mise upgrade

section "Agent CLIs"
run_if_available codex codex update
run_if_available claude claude update
run_if_available opencode opencode upgrade

section "Skills"
run_if_available npm npx -y skills@latest update -g -y

section "npm global"
run_if_available npm npm update -g

section "Firmware"
run_fwupdmgr refresh
run_fwupdmgr update

section "Mouse"
show_mouse_battery_level
