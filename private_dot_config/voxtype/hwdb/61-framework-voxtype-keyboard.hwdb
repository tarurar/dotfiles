# Framework Laptop 13 internal keyboard: make AltGr trigger Voxtype.
#
# The laptop has no physical Right Meta key. Voxtype listens for RIGHTMETA so
# the external NuPhy right meta key keeps working. Remap the laptop AltGr
# scan code to rightmeta, scoped to the Framework internal AT keyboard.
evdev:atkbd:dmi:bvn*:bvr*:bd*:svnFramework:pnLaptop13*:pvrA9:*
 KEYBOARD_KEY_b8=rightmeta
