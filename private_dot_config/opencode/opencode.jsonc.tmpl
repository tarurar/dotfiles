{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 15000,
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "bin/**",
      "obj/**",
      "*.log",
    ],
  },
  "formatter": {
    "csharpier": {
      "command": [
        "csharpier",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".cs",
        ".csx",
        ".csproj",
        ".props",
        ".targets",
        ".config",
        ".slnx",
        ".xml",
      ],
    },
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
      "timeout": 40000,
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
      "enabled": true,
      "oauth": false,
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}",
      },
    },
  },
  "model": {{ if eq .chezmoi.os "darwin" }}"kimi-for-coding-oauth/kimi-for-coding"{{ else }}"openai/gpt-5.5"{{ end }},
  "small_model": {{ if eq .chezmoi.os "darwin" }}"kimi-for-coding-oauth/kimi-for-coding"{{ else }}"openai/gpt-5.4-mini-fast"{{ end }},
  "agent": {
    "build": {
      "description": "Primary build agent: write, edit, test, debug, dispatch subagents",
      "mode": "primary",
      "model": {{ if eq .chezmoi.os "darwin" }}"kimi-for-coding-oauth/kimi-for-coding"{{ else }}"openai/gpt-5.5-build"{{ end }},
      "prompt": "{file:./prompts/build.md}",
      "color": "accent",
    },
    "explain": {
      "description": "Teaching mode: verbose step-by-step with rationale",
      "mode": "primary",
      "model": {{ if eq .chezmoi.os "darwin" }}"kimi-for-coding-oauth/kimi-for-coding"{{ else }}"openai/gpt-5.5-explain"{{ end }},
      "prompt": "{file:./prompts/explain.md}",
      "color": "info",
    },
    "Aid Agent": {
      "description": "Primary agent for the AID real-time notifications assignment",
      "mode": "primary",
      "model": "openai/gpt-5.5-general",
      "variant": "high",
      "prompt": "{file:./prompts/aid-agent.md}",
      "color": "success",
    },
    "terse": {
      "description": "Senior engineer: minimal preamble, code-first",
      "mode": "primary",
      "model": {{ if eq .chezmoi.os "darwin" }}"kimi-for-coding-oauth/kimi-for-coding"{{ else }}"openai/gpt-5.4-mini-terse"{{ end }},
      "prompt": "Respond with code first. One-line rationale only when non-obvious. No preamble.",
      "color": "warning",
    },
    "plan": {
      "description": "High-reasoning planner with read-only permissions",
      "mode": "primary",
      "model": {{ if eq .chezmoi.os "darwin" }}"kimi-for-coding-oauth/kimi-for-coding"{{ else }}"openai/gpt-5.5-planner"{{ end }},
      "prompt": "{file:./prompts/planner.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
        },
        "webfetch": "allow",
      },
      "color": "info",
    },
    "fast-edit": {
      "description": "Single-edit executor: read/edit/bash only, no planning",
      "mode": "subagent",
      "model": {{ if eq .chezmoi.os "darwin" }}"kimi-for-coding-oauth/kimi-for-coding"{{ else }}"openai/gpt-5.4-mini-fast-edit"{{ end }},
      "prompt": "Execute the requested change. No commentary. Call edit or bash tools directly.",
      "permission": {
        "edit": "allow",
        "bash": {
          "rm *": "deny",
          "git push*": "deny",
          "*": "allow",
        },
        "webfetch": "deny",
        "task": {
          "*": "deny",
        },
      },
      "color": "error",
    },
    "strict": {
      "description": "JSON-strict tool-forced executor",
      "mode": "subagent",
      "model": {{ if eq .chezmoi.os "darwin" }}"kimi-for-coding-oauth/kimi-for-coding"{{ else }}"openai/gpt-5.4-mini-strict"{{ end }},
      "prompt": "Respond exclusively by calling the provided tool with valid JSON arguments.",
      "color": "error",
    },
    "explore": {
      "description": "Read-only code exploration: maps structure, finds references, reports findings",
      "mode": "subagent",
      "model": {{ if eq .chezmoi.os "darwin" }}"kimi-for-coding-oauth/kimi-for-coding"{{ else }}"openai/gpt-5.4-mini-explore"{{ end }},
      "prompt": "{file:./prompts/explore.md}",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git diff*": "allow",
          "git status*": "allow",
          "wc *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "tree *": "allow",
          "*": "deny",
        },
        "webfetch": "deny",
        "task": {
          "*": "deny",
        },
      },
      "color": "success",
    },
    "advisor": {
      "description": "Learn a topic from source code and docs, then produce actionable recommendation",
      "mode": "primary",
      "model": {{ if eq .chezmoi.os "darwin" }}"kimi-for-coding-oauth/kimi-for-coding"{{ else }}"openai/gpt-5.5-advisor"{{ end }},
      "prompt": "{file:./prompts/advisor.md}",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "ls *": "allow",
          "cat *": "allow",
          "tree *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git diff*": "allow",
          "git clone *": "allow",
          "gh repo view*": "allow",
          "gh pr view*": "allow",
          "gh issue view*": "allow",
          "curl -s http*": "allow",
          "curl -sL http*": "allow",
          "*": "deny",
        },
        "webfetch": "allow",
        "task": {
          "*": "deny",
        },
      },
      "color": "info",
    },
    "general": {
      "mode": "subagent",
      "model": "openai/gpt-5.5-general",
      "variant": "high",
      "color": "accent",
    },
    "gpt-general": {
      "mode": "primary",
      "model": "openai/gpt-5.5-general",
      "variant": "high",
      "color": "accent",
    },
    "kimi-agent": {
      "mode": "primary",
      "model": "kimi-for-coding-oauth/kimi-for-coding",
      "color": "warning",
      "variant": "high"
    },
    "kimi-k2.7": {
      "mode": "primary",
      "model": "openrouter/moonshotai/kimi-k2.7-code",
      "color": "warning",
    },
    "Fusion Agent": {
      "mode": "primary",
      "model": "openrouter/fusion",
      "color": "accent",
    },
    "deepseek-general": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-pro-coder",
      "variant": "high",
      "color": "success",
    },
  },
  "snapshot": true,
  "share": "manual",
  "permission": {
    "read": {
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.envrc": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/id_rsa*": "deny",
      "**/id_ed25519*": "deny",
      "**/*.pfx": "deny",
      "**/*secret*": "deny",
      "**/*credential*": "deny",
      "**/*": "allow",
    },
    "bash": {
      "cat *.env*": "deny",
      "cat .env*": "deny",
      "cat **/.env*": "deny",
      "less *.env*": "deny",
      "less .env*": "deny",
      "head *.env*": "deny",
      "tail *.env*": "deny",
      "grep * *.env*": "deny",
      "grep * .env*": "deny",
      "rg * *.env*": "deny",
      "rg * .env*": "deny",
      "printenv": "deny",
      "env": "deny",
      "rm -rf *": "deny",
      "sudo *": "ask",
      "*": "allow",
    },
    "edit": "allow",
    "webfetch": "allow",
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow",
      "~/.local/share/chezmoi/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.local/share/opencode/worktree/**": "allow",
    },
    "doom_loop": "ask",
  },
  "username": "Andrei",
  "plugin": [
    // "superpowers@git+https://github.com/obra/superpowers.git#v5.1.0",
    "opencode-kimi-full",
  ],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5-build": {
          "id": "gpt-5.5",
          "name": "GPT-5.5 Build",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "medium",
            "reasoningSummary": "auto",
            "serviceTier": "priority",
            "include": [
              "reasoning.encrypted_content"
            ],
          },
        },
        "gpt-5.5-explain": {
          "id": "gpt-5.5",
          "name": "GPT-5.5 Explain",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "high",
            "reasoningSummary": "auto",
            "include": [
              "reasoning.encrypted_content"
            ],
          },
        },
        "gpt-5.4-mini-terse": {
          "id": "gpt-5.4-mini",
          "name": "GPT-5.4 Mini Terse",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "reasoningSummary": "auto",
            "serviceTier": "priority",
            "include": [
              "reasoning.encrypted_content"
            ],
          },
        },
        "gpt-5.5-planner": {
          "id": "gpt-5.5",
          "name": "GPT-5.5 Planner",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "medium",
            "reasoningSummary": "auto",
            "promptCacheKey": "planner-{sessionId}",
            "include": [
              "reasoning.encrypted_content"
            ],
          },
        },
        "gpt-5.4-mini-fast-edit": {
          "id": "gpt-5.4-mini",
          "name": "GPT-5.4 Mini Fast Edit",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "serviceTier": "priority",
          },
        },
        "gpt-5.4-mini-strict": {
          "id": "gpt-5.4-mini",
          "name": "GPT-5.4 Mini Strict",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "none",
            "textVerbosity": "low",
            "reasoningSummary": "auto",
            "toolChoice": "required",
            "include": [
              "reasoning.encrypted_content"
            ],
          },
        },
        "gpt-5.4-mini-explore": {
          "id": "gpt-5.4-mini",
          "name": "GPT-5.4 Mini Explore",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "reasoningSummary": "auto",
            "include": [
              "reasoning.encrypted_content"
            ],
          },
        },
        "gpt-5.5-advisor": {
          "id": "gpt-5.5",
          "name": "GPT-5.5 Advisor",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "xhigh",
            "serviceTier": "priority",
            "textVerbosity": "medium",
            "reasoningSummary": "auto",
            "include": [
              "reasoning.encrypted_content"
            ],
          },
        },
        "gpt-5.5-general": {
          "id": "gpt-5.5",
          "name": "GPT-5.5 General (High+Fast)",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "high",
            "serviceTier": "priority",
            "textVerbosity": "medium",
            "reasoningSummary": "auto",
            "include": [
              "reasoning.encrypted_content"
            ],
          },
        },
      },
    },
    "ollama-cloud": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Cloud",
      "options": {
        "baseURL": "https://ollama.com/v1",
        "apiKey": "{env:OLLAMA_API_KEY}",
        "timeout": 300000,
        "chunkTimeout": 60000,
      },
      "models": {
        "glm-5.1:cloud": {
          "name": "GLM 5.1 Cloud",
        },
        "minimax-m2.7:cloud": {
          "name": "MiniMax M2.7 Cloud",
        },
        "qwen3.5:cloud": {
          "name": "Qwen 3.5 Cloud",
        },
        "kimi-k2.5:cloud": {
          "name": "Kimi 2.5 Cloud",
        },
      },
    },
    "zai-coding-plan": {
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4",
        "timeout": 600000,
        "chunkTimeout": 300000,
      },
      "models": {
        "glm-5.1": {
          "name": "GLM-5.1",
          "reasoning": true,
        },
        "glm-5": {
          "name": "GLM-5",
          "reasoning": true,
        },
        "glm-5-turbo": {
          "name": "GLM-5-Turbo",
          "reasoning": true,
        },
        "glm-4.7": {
          "name": "GLM-4.7",
          "reasoning": true,
        },
        "glm-4.6v": {
          "name": "GLM-4.6V",
          "reasoning": true,
        },
        "glm-4.5-air": {
          "name": "GLM-4.5-Air",
          "reasoning": true,
        },
        "glm-4.5-flash": {
          "name": "GLM-4.5-Flash",
        },
        "glm-4.7-flash": {
          "name": "GLM-4.7-Flash",
        },
        "glm-4.7-flashx": {
          "name": "GLM-4.7-FlashX",
        },
      },
    },
    "openrouter": {
      "options": {
        "timeout": 300000,
        "chunkTimeout": 60000,
      },
      "models": {
        "moonshotai/kimi-k2.6": {
          "name": "Kimi K2.6 (fastest throughput)",
          "options": {
            "provider": {
              "sort": "throughput",
              "allow_fallbacks": true,
            },
          },
        },
        "moonshotai/kimi-k2.7-code": {
          "name": "Kimi K2.7 Code (fastest throughput)",
          "options": {
            "provider": {
              "sort": "throughput",
              "allow_fallbacks": true,
            },
          },
        },
        "deepseek/deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro (fastest throughput)",
          "options": {
            "provider": {
              "sort": "throughput",
              "allow_fallbacks": true,
            },
          },
        },
        "z-ai/glm-5.1": {
          "name": "GLM 5.1 (fastest throughput)",
          "options": {
            "provider": {
              "sort": "throughput",
              "allow_fallbacks": true,
            },
          },
        },
        "minimax/minimax-m3": {
          "name": "MiniMax M3 (fastest throughput)",
          "options": {
            "provider": {
              "sort": "throughput",
              "allow_fallbacks": true,
            },
          },
        },
        "anthropic/claude-opus-4.6": {
          "name": "Claude Opus 4.6",
        },
        "anthropic/claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
        },
        "anthropic/claude-haiku-4.5": {
          "name": "Claude Haiku 4.5",
        },
        "fusion": {
          "id": "openrouter/fusion",
          "name": "Fusion",
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 32768
          }
        },
      },
    },
    "minimax": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://api.minimax.io/anthropic/v1",
        "apiKey": "{env:MINIMAX_API_KEY}",
        "timeout": 300000,
        "chunkTimeout": 60000,
      },
      "models": {
        "MiniMax-M2.7-highspeed": {
          "name": "MiniMax-M2.7-highspeed",
        },
      },
    },
    "deepseek": {
      "api": "https://api.deepseek.com",
      "env": [
        "DEEPSEEK_API_KEY"
      ],
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "deepseek-v4-pro-coder": {
          "id": "deepseek-v4-pro",
          "name": "DeepSeek V4 Pro (Coder)",
          "options": {
            "thinking": {
              "type": "enabled",
            },
            "reasoningEffort": "high",
          },
          "variants": {
            "low": {
              "disabled": true,
            },
            "medium": {
              "disabled": true,
            },
            "high": {
              "thinking": {
                "type": "enabled",
              },
              "reasoningEffort": "high",
            },
            "max": {
              "thinking": {
                "type": "enabled",
              },
              "reasoningEffort": "max",
            },
          },
        },
        "deepseek-v4-flash-fast": {
          "id": "deepseek-v4-flash",
          "name": "DeepSeek V4 Flash (Fast, no thinking)",
          "options": {
            "thinking": {
              "type": "disabled",
            },
          },
        },
        "deepseek-v4-pro-reasoner": {
          "id": "deepseek-v4-pro",
          "name": "DeepSeek V4 Pro (Reasoner)",
          "options": {
            "thinking": {
              "type": "enabled",
            },
            "reasoningEffort": "max",
          },
          "variants": {
            "low": {
              "disabled": true,
            },
            "medium": {
              "disabled": true,
            },
            "high": {
              "thinking": {
                "type": "enabled",
              },
              "reasoningEffort": "high",
            },
            "max": {
              "thinking": {
                "type": "enabled",
              },
              "reasoningEffort": "max",
            },
          },
        },
      },
    },
    "kimi-for-coding-oauth": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Kimi Subscription (OAuth)",
      "options": {
        "baseURL": "https://api.kimi.com/coding/v1"
      },
      "models": {
        "kimi-for-coding": {
          "name": "K2.7 Code",
          "reasoning": true,
          "options": {},
          "variants": {
            "off": {
              "reasoning_effort": "off"
            },
            "auto": {
              "reasoning_effort": "auto"
            },
            "low": {
              "reasoning_effort": "low"
            },
            "medium": {
              "reasoning_effort": "medium"
            },
            "high": {
              "reasoning_effort": "high"
            }
          },
          "limit": {
            "context": 262144,
            "output": 32768
          },
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "instructions": [
    "AGENTS.md",
    "~/.config/opencode/rules/rtk.md"
  ],
}
