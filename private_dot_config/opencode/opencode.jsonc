{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 15000,
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      "bin/**",
      "obj/**",
      "*.log",
    ],
  },
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": ["context-mode"],
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp?tools=web_search_exa,web_fetch_exa,web_search_advanced_exa",
      "enabled": true,
      "oauth": false,
      "headers": {
        "x-api-key": "{env:EXA_API_KEY}",
      },
    },
  },
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini-fast",
  //"model": "kimi-for-coding/k2p6",
  "agent": {
    "build": {
      "description": "Primary build agent: write, edit, test, debug, dispatch subagents",
      "mode": "primary",
      "model": "openai/gpt-5.5-build",
      //"model": "kimi-for-coding/k2p6-build",
      "prompt": "{file:./prompts/build.md}",
      "color": "accent",
    },
    "explain": {
      "description": "Teaching mode: verbose step-by-step with rationale",
      "mode": "primary",
      "model": "openai/gpt-5.5-explain",
      //"model": "kimi-for-coding/k2p6-explain",
      "prompt": "{file:./prompts/explain.md}",
      "color": "info",
    },
    "terse": {
      "description": "Senior engineer: minimal preamble, code-first",
      "mode": "primary",
      "model": "openai/gpt-5.4-mini-terse",
      //"model": "kimi-for-coding/k2p6-terse",
      "prompt": "Respond with code first. One-line rationale only when non-obvious. No preamble.",
      "color": "warning",
    },
    "plan": {
      "description": "High-reasoning planner with read-only permissions",
      "mode": "primary",
      "model": "openai/gpt-5.5-planner",
      //"model": "kimi-for-coding/k2p6-planner",
      "prompt": "{file:./prompts/planner.md}",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
        },
        "webfetch": "allow",
      },
      "color": "info",
    },
    "fast-edit": {
      "description": "Single-edit executor: read/edit/bash only, no planning",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini-fast-edit",
      //"model": "kimi-for-coding/k2p6-fast",
      "prompt": "Execute the requested change. No commentary. Call edit or bash tools directly.",
      "permission": {
        "edit": "allow",
        "bash": {
          "rm *": "deny",
          "git push*": "deny",
          "*": "allow",
        },
        "webfetch": "deny",
        "task": {
          "*": "deny",
        },
      },
      "color": "error",
    },
    "strict": {
      "description": "JSON-strict tool-forced executor",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini-strict",
      //"model": "kimi-for-coding/k2p6-strict",
      "prompt": "Respond exclusively by calling the provided tool with valid JSON arguments.",
      "color": "error",
    },
    "explore": {
      "description": "Read-only code exploration: maps structure, finds references, reports findings",
      "mode": "subagent",
      "model": "openai/gpt-5.4-mini-explore",
      //"model": "kimi-for-coding/k2p6-explore",
      "prompt": "{file:./prompts/explore.md}",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "ls *": "allow",
          "cat *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git diff*": "allow",
          "git status*": "allow",
          "wc *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "tree *": "allow",
          "*": "deny",
        },
        "webfetch": "deny",
        "task": {
          "*": "deny",
        },
      },
      "color": "success",
    },
    "advisor": {
      "description": "Learn a topic from source code and docs, then produce actionable recommendation",
      "mode": "primary",
      "model": "openai/gpt-5.5-advisor",
      //"model": "kimi-for-coding/k2p6-advisor",
      "prompt": "{file:./prompts/advisor.md}",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": {
          "ls *": "allow",
          "cat *": "allow",
          "tree *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "find *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git diff*": "allow",
          "git clone *": "allow",
          "gh repo view*": "allow",
          "gh pr view*": "allow",
          "gh issue view*": "allow",
          "curl -s http*": "allow",
          "curl -sL http*": "allow",
          "*": "deny",
        },
        "webfetch": "allow",
        "task": {
          "*": "deny",
        },
      },
      "color": "info",
    },
  },
  "snapshot": true,
  "share": "manual",
  "permission": {
    "read": {
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.envrc": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/id_rsa*": "deny",
      "**/id_ed25519*": "deny",
      "**/*.pfx": "deny",
      "**/*secret*": "deny",
      "**/*credential*": "deny",
      "**/*": "allow",
    },
    "bash": {
      "cat *.env*": "deny",
      "cat .env*": "deny",
      "cat **/.env*": "deny",
      "less *.env*": "deny",
      "less .env*": "deny",
      "head *.env*": "deny",
      "tail *.env*": "deny",
      "grep * *.env*": "deny",
      "grep * .env*": "deny",
      "rg * *.env*": "deny",
      "rg * .env*": "deny",
      "printenv": "deny",
      "env": "deny",
      "rm -rf *": "deny",
      "sudo *": "ask",
      "*": "allow",
    },
    "edit": "allow",
    "webfetch": "allow",
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow",
      "~/.local/share/chezmoi/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.local/share/opencode/worktree/**": "allow",
    },
    "doom_loop": "ask",
  },
  "server": {
    "port": 4096,
    "hostname": "127.0.0.1",
  },
  "username": "Andrei",
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git#v5.1.0",
    "context-mode",
  ],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.5-build": {
          "id": "gpt-5.5",
          "name": "GPT-5.5 Build",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "medium",
            "reasoningSummary": "auto",
            "serviceTier": "priority",
            "include": ["reasoning.encrypted_content"],
          },
        },
        "gpt-5.5-explain": {
          "id": "gpt-5.5",
          "name": "GPT-5.5 Explain",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "high",
            "reasoningSummary": "auto",
            "include": ["reasoning.encrypted_content"],
          },
        },
        "gpt-5.4-mini-terse": {
          "id": "gpt-5.4-mini",
          "name": "GPT-5.4 Mini Terse",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "reasoningSummary": "auto",
            "serviceTier": "priority",
            "include": ["reasoning.encrypted_content"],
          },
        },
        "gpt-5.5-planner": {
          "id": "gpt-5.5",
          "name": "GPT-5.5 Planner",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "medium",
            "reasoningSummary": "auto",
            "promptCacheKey": "planner-{sessionId}",
            "include": ["reasoning.encrypted_content"],
          },
        },
        "gpt-5.4-mini-fast-edit": {
          "id": "gpt-5.4-mini",
          "name": "GPT-5.4 Mini Fast Edit",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "serviceTier": "priority",
          },
        },
        "gpt-5.4-mini-strict": {
          "id": "gpt-5.4-mini",
          "name": "GPT-5.4 Mini Strict",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "none",
            "textVerbosity": "low",
            "reasoningSummary": "auto",
            "toolChoice": "required",
            "include": ["reasoning.encrypted_content"],
          },
        },
        "gpt-5.4-mini-explore": {
          "id": "gpt-5.4-mini",
          "name": "GPT-5.4 Mini Explore",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "reasoningSummary": "auto",
            "include": ["reasoning.encrypted_content"],
          },
        },
        "gpt-5.5-advisor": {
          "id": "gpt-5.5",
          "name": "GPT-5.5 Advisor",
          "reasoning": true,
          "tool_call": true,
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "medium",
            "reasoningSummary": "auto",
            "include": ["reasoning.encrypted_content"],
          },
        },
      },
    },
    "ollama-cloud": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Cloud",
      "options": {
        "baseURL": "https://ollama.com/v1",
        "apiKey": "{env:OLLAMA_API_KEY}",
        "timeout": 300000,
        "chunkTimeout": 60000,
      },
      "models": {
        "glm-5.1:cloud": {
          "name": "GLM 5.1 Cloud",
        },
        "minimax-m2.7:cloud": {
          "name": "MiniMax M2.7 Cloud",
        },
        "qwen3.5:cloud": {
          "name": "Qwen 3.5 Cloud",
        },
        "kimi-k2.5:cloud": {
          "name": "Kimi 2.5 Cloud",
        },
      },
    },
    "zai-coding-plan": {
      "options": {
        "baseURL": "https://api.z.ai/api/coding/paas/v4",
        "timeout": 600000,
        "chunkTimeout": 300000,
      },
      "models": {
        "glm-5.1": {
          "name": "GLM-5.1",
          "reasoning": true,
        },
        "glm-5": {
          "name": "GLM-5",
          "reasoning": true,
        },
        "glm-5-turbo": {
          "name": "GLM-5-Turbo",
          "reasoning": true,
        },
        "glm-4.7": {
          "name": "GLM-4.7",
          "reasoning": true,
        },
        "glm-4.6v": {
          "name": "GLM-4.6V",
          "reasoning": true,
        },
        "glm-4.5-air": {
          "name": "GLM-4.5-Air",
          "reasoning": true,
        },
        "glm-4.5-flash": {
          "name": "GLM-4.5-Flash",
        },
        "glm-4.7-flash": {
          "name": "GLM-4.7-Flash",
        },
        "glm-4.7-flashx": {
          "name": "GLM-4.7-FlashX",
        },
      },
    },
    "openrouter": {
      "options": {
        "timeout": 300000,
        "chunkTimeout": 60000,
      },
      "models": {
        "anthropic/claude-opus-4.6": {
          "name": "Claude Opus 4.6",
        },
        "anthropic/claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
        },
        "anthropic/claude-haiku-4.5": {
          "name": "Claude Haiku 4.5",
        },
      },
    },
    "minimax": {
      "npm": "@ai-sdk/anthropic",
      "options": {
        "baseURL": "https://api.minimax.io/anthropic/v1",
        "apiKey": "{env:MINIMAX_API_KEY}",
        "timeout": 300000,
        "chunkTimeout": 60000,
      },
      "models": {
        "MiniMax-M2.7-highspeed": {
          "name": "MiniMax-M2.7-highspeed",
        },
      },
    },
    "kimi-for-coding": {
      "models": {
        "k2p6-explain": {
          "id": "k2p6",
          "name": "K2.6 Explain",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 32768,
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "keep": "all",
            },
            "reasoning_effort": "high",
            "interleaved": {
              "field": "reasoning_content",
            },
          },
        },
        "k2p6-terse": {
          "id": "k2p6",
          "name": "K2.6 Terse",
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 8192,
          },
          "options": {
            "thinking": {
              "type": "disabled",
            },
          },
        },
        "k2p6-planner": {
          "id": "k2p6",
          "name": "K2.6 Planner",
          "reasoning": true,
          "limit": {
            "context": 262144,
            "output": 32768,
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "keep": "all",
            },
            "reasoning_effort": "high",
            "prompt_cache_key": "planner-{sessionId}",
            "interleaved": {
              "field": "reasoning_content",
            },
          },
        },
        "k2p6-fast": {
          "id": "k2p6",
          "name": "K2.6 Fast Executor",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 8192,
          },
          "options": {
            "thinking": {
              "type": "disabled",
            },
          },
        },
        "k2p6-strict": {
          "id": "k2p6",
          "name": "K2.6 Strict",
          "tool_call": true,
          "limit": {
            "context": 131072,
            "output": 8192,
          },
          "options": {
            "thinking": {
              "type": "disabled",
            },
            "response_format": {
              "type": "json_schema",
              "json_schema": {
                "name": "tool_call_result",
                "strict": true,
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                    },
                    "summary": {
                      "type": "string",
                    },
                  },
                  "required": ["ok", "summary"],
                  "additionalProperties": false,
                },
              },
            },
            "tool_choice": "required",
          },
        },
        "k2p6-explore": {
          "id": "k2p6",
          "name": "K2.6 Explorer",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 16384,
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "keep": "all",
            },
            "reasoning_effort": "low",
            "interleaved": {
              "field": "reasoning_content",
            },
          },
        },
        "k2p6-advisor": {
          "id": "k2p6",
          "name": "K2.6 Advisor",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 32768,
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "keep": "all",
            },
            "reasoning_effort": "high",
            "interleaved": {
              "field": "reasoning_content",
            },
          },
        },
        "k2p6-build": {
          "id": "k2p6",
          "name": "K2.6 Build",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 262144,
            "output": 16384,
          },
          "options": {
            "thinking": {
              "type": "enabled",
              "keep": "all",
            },
            "reasoning_effort": "medium",
            "interleaved": {
              "field": "reasoning_content",
            },
          },
        },
      },
    },
    "deepseek": {
      "models": {
        "deepseek-v4-pro-coder": {
          "id": "deepseek-v4-pro",
          "name": "DeepSeek V4 Pro (Coder)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1048576,
            "output": 262144,
          },
          "interleaved": {
            "field": "reasoning_content",
          },
          "options": {
            "thinking": {
              "type": "enabled",
            },
            "reasoning_effort": "high",
            "reasoningEffort": "high",
          },
        },
        "deepseek-v4-flash-fast": {
          "id": "deepseek-v4-flash",
          "name": "DeepSeek V4 Flash (Fast, no thinking)",
          "tool_call": true,
          "limit": {
            "context": 1048576,
            "output": 262144,
          },
          "options": {
            "thinking": {
              "type": "disabled",
            },
          },
        },
        "deepseek-v4-pro-reasoner": {
          "id": "deepseek-v4-pro",
          "name": "DeepSeek V4 Pro (Reasoner)",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1048576,
            "output": 262144,
          },
          "interleaved": {
            "field": "reasoning_content",
          },
          "options": {
            "thinking": {
              "type": "enabled",
            },
            "reasoning_effort": "max",
            "reasoningEffort": "max",
          },
        },
      },
    },
  },
  "instructions": ["AGENTS.md", "~/.config/opencode/rules/rtk.md"],
}
